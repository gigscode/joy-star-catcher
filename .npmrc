# 24h supply-chain guard: skip package versions published less than a day ago.
# npm 11.10+ uses `min-release-age` and expresses the value in days.
# Mirrors the previous bunfig.toml setting (which used seconds).
# With package-lock.json committed, this only affects new adds / version bumps,
# not routine `npm install` / `npm ci`.
min-release-age=1
# NOTE: npm does NOT yet support per-package exclusions (Bun had
# `minimumReleaseAgeExcludes`). If a fresh @lovable.dev/* release needs to be
# pulled in before the 1-day window, install it with the flag disabled, e.g.
#   npm install @lovable.dev/vite-tanstack-config@<version> --min-release-age=0
